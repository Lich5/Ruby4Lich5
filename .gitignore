# Pester's own default NUnit-format test-result output, written to the repo
# root by Invoke-Pester unless $config.TestResult.Enabled is explicitly set
# to $false -- a local run byproduct, not something to commit. Real gap
# found in review 2026-07-12: it landed in a real commit on this branch.
/testResults.xml
/test/tmp/
/test/version_tmp/
/tmp/

/.bundle/
/lib/bundler/man/

# Dev/lint-only tooling deps (rspec, rubocop) -- not runtime code the
# factory's output depends on, so pinning exact versions in git isn't
# protecting reproducibility of anything shipped. Revisit once the Gemfile
# picks up real runtime dependencies.
Gemfile.lock

.rvmrc
.ruby-version.local

.DS_Store
